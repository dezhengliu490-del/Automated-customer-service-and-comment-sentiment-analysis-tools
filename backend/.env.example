# =============================================================================
# Backend environment template
# 复制本文件为 .env 后填写真实值（.env 已被 .gitignore 忽略，勿提交）
# Copy this file to ".env" and fill in values. Never commit ".env".
# =============================================================================

# Google Gemini API Key（必填其一）
# Get a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# 若你更习惯用官方文档里的变量名，可与上面二选一（config 会读）
# GOOGLE_API_KEY=

# 可选：指定模型；不填则默认 gemini-2.0-flash
# Optional model id; default is gemini-2.0-flash if unset.
# GEMINI_MODEL=gemini-2.0-flash

# Reliability and throughput tuning
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=3
LLM_RETRY_BASE_DELAY=0.8
LLM_RETRY_MAX_DELAY=8
LLM_MAX_CONCURRENCY=8
LLM_RATE_LIMIT_RPS=5
LLM_MAX_INPUT_CHARS=6000
LLM_LOG_PATH=backend/logs/llm_calls.jsonl
